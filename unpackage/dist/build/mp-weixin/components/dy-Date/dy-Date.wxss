.date-picker{width:100%;height:40px;border-radius:8px;border:1px solid #e4e7ed;background:#fff;padding:0 12px;transition:all .3s ease;position:relative;min-width:-webkit-fit-content;min-width:fit-content;max-width:128px}.date-picker:active{background-color:#f8f9fa;box-shadow:0 0 0 3px rgba(64,158,255,.1)}.date-picker .uni-input{font-size:14px;color:#303133;line-height:40px}.date-picker .placeholder{color:#b5b8c2;font-size:14px;line-height:40px}@media screen and (max-width:480px){.date-picker{height:36px}.date-picker .uni-input,
  .date-picker .placeholder{font-size:13px;line-height:36px}}.tx_r{line-height:48px;font-size:15px;font-weight:400;color:#848b9a}.placeholder{color:#b5b8c2;font-size:30rpx}.fa-angle-right{font-size:36rpx;padding-left:12rpx}