page{background-color:#f5f7fa;font-family:-apple-system,BlinkMacSystemFont,Helvetica Neue,Helvetica,PingFang SC,Hiragino Sans GB,Microsoft YaHei,Arial,sans-serif}.container{padding:30rpx}.header{margin-top:50px;margin-bottom:40rpx;padding:20rpx 0;background:linear-gradient(135deg,#409eff,#06c);border-radius:16rpx}.title{font-size:40rpx;font-weight:600;color:#fff;padding-left:30rpx}.title::before{content:"";display:inline-block;width:8rpx;height:40rpx;background-color:#409eff;border-radius:4rpx;margin-right:16rpx}.system-list{display:flex;flex-direction:column;gap:24rpx}.system-card{background:#fff;border-radius:20rpx;padding:32rpx;box-shadow:0 6rpx 20rpx rgba(0,0,0,.08);display:flex;align-items:center;transition:all .3s ease;position:relative;overflow:hidden}.system-card:active{-webkit-transform:scale(.98);transform:scale(.98)}.system-card.active-card{border-left:8rpx solid #409eff;box-shadow:0 8rpx 24rpx rgba(64,158,255,.15)}.system-icon{width:80rpx;height:80rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-right:24rpx;font-size:36rpx;font-weight:700;color:#fff;flex-shrink:0}.icon-energy{background-color:#52c41a}.icon-carbon{background-color:#fa8c16}.icon-platform{background-color:#409eff}.icon-unknown{background-color:#909399}.icon-text{-webkit-transform:scale(1.2);transform:scale(1.2)}.system-info{flex:1}.system-name{font-size:32rpx;color:#303133;font-weight:500;margin-bottom:8rpx;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.system-type{font-size:24rpx;color:#909399;display:block}.arrow-right{width:40rpx;height:40rpx;display:flex;align-items:center;justify-content:center;color:#c0c4cc;margin-left:24rpx;transition:-webkit-transform .3s ease;transition:transform .3s ease;transition:transform .3s ease,-webkit-transform .3s ease}.system-card:hover .arrow-right,
.system-card.active-card .arrow-right{-webkit-transform:translateX(10rpx);transform:translateX(10rpx);color:#409eff}.iconfont{font-family:iconfont!important;font-size:28rpx;font-style:normal;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}.icon-arrow::before{content:"\e62f"}