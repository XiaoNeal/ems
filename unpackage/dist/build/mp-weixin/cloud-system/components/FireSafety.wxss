.container{padding:24rpx;min-height:100vh;background:#f5f7fa;display:flex;flex-direction:column;gap:32rpx}.cooling-panel,
.environment-panel,
.fire-panel{background:#fff;border-radius:24rpx;box-shadow:0 8rpx 24rpx rgba(0,0,0,.06);margin-bottom:32rpx}.container{padding:32rpx;min-height:100vh;background:#f5f7fa;display:flex;flex-direction:column;gap:40rpx;box-sizing:border-box;padding-bottom:64rpx;margin-bottom:env(safe-area-inset-bottom)}.cooling-panel{flex:0 0 auto;min-height:420rpx}.cooling-panel .data-list{padding:24rpx}.cooling-panel .data-list .data-item{padding:32rpx;margin:0 0 24rpx;background:#f8f9fb;border-radius:16rpx}.environment-panel .sensor-grid{padding:32rpx;gap:40rpx}.environment-panel .sensor-grid .env-item{padding:32rpx;border-radius:16rpx;display:flex;align-items:center}.environment-panel .sensor-grid .env-item .sensor-icon{width:80rpx;height:80rpx;margin-right:24rpx}.environment-panel .sensor-grid .env-item .env-value{font-size:48rpx;font-weight:600}.fire-panel{flex:1}.fire-panel .device-grid{padding:24rpx;gap:32rpx}.fire-panel .device-grid .module-item{margin:0}.device-box{flex:1;display:flex;flex-direction:column;gap:24rpx}.right-panel,
.environment-box{background:linear-gradient(135deg,#f8fafc,#f1f5f9);border-radius:16rpx;padding:32rpx;display:flex;justify-content:space-around}.right-panel .env-item,
.environment-box .env-item{display:flex;align-items:center;font-size:28rpx}.right-panel .env-item .env-value,
.environment-box .env-item .env-value{font-size:36rpx;font-weight:600;color:#409eff;margin:0 12rpx}.fire-panel{flex:1;background:#fff;border-radius:16rpx;box-shadow:0 4rpx 12rpx rgba(0,0,0,.08)}.fire-panel .panel-header{padding:24rpx;border-bottom:1rpx solid #eee}.fire-panel .panel-header .header-text{font-size:32rpx;font-weight:600;color:#303133}.fire-panel .panel-header .module-count{font-size:26rpx;color:#909399}.module-item{padding:24rpx;margin:16rpx;background:#fff;border-radius:12rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.06);transition:all .3s}.module-item:hover{-webkit-transform:translateY(-2rpx);transform:translateY(-2rpx);box-shadow:0 4rpx 16rpx rgba(0,0,0,.12)}.status-label{padding:6rpx 20rpx;border-radius:24rpx;font-size:24rpx}.status-label.normal{background:#e8f4ff;color:#409eff}.status-label.abnormal{background:#fef0f0;color:#f56c6c}.detail-item{display:block;font-size:26rpx;color:#606266;line-height:1.6;margin-bottom:12rpx}.detail-item:last-child{margin-bottom:0}.scroll-content{height:calc(100vh - 160rpx)}.scroll-content::-webkit-scrollbar{width:6rpx}.scroll-content::-webkit-scrollbar-thumb{background:#c0c4cc;border-radius:4rpx}.normal{background:#e8f5e9;color:#2e7d32}.abnormal{background:#ffebee;color:#c62828}.cooling-panel{min-height:480rpx}.cooling-panel .data-list{padding:32rpx;display:grid;grid-template-columns:repeat(2,1fr);gap:32rpx}.cooling-panel .data-list .data-item{padding:32rpx;background:#f8f9fb;border-radius:16rpx;display:flex;flex-direction:column;align-items:center}.cooling-panel .data-list .data-item .data-name{font-size:28rpx;color:#909399}.cooling-panel .data-list .data-item .data-value{font-size:40rpx;color:#303133;margin-top:16rpx}.environment-panel .env-item{padding:40rpx 32rpx;border-radius:24rpx;margin:0 16rpx}.environment-panel .env-item .sensor-icon{width:96rpx;height:96rpx}.environment-panel .env-item .env-value{font-size:52rpx}.fire-panel .data-list{grid-template-columns:repeat(auto-fit,minmax(300rpx,1fr));gap:32rpx}.fire-panel .data-list .data-item{padding:40rpx 32rpx;background:linear-gradient(145deg,#f8f9fb,#fff);box-shadow:0 12rpx 40rpx rgba(0,0,0,.08);border:1rpx solid #f0f2f5;transition:all .3s cubic-bezier(.4,0,.2,1)}.fire-panel .data-list .data-item:hover{-webkit-transform:translateY(-6rpx);transform:translateY(-6rpx);box-shadow:0 16rpx 48rpx rgba(0,0,0,.12)}.fire-panel .data-list .data-item .data-name{font-size:30rpx;color:#606266;margin-bottom:16rpx;font-weight:500}.fire-panel .data-list .data-item .data-value{font-size:48rpx;font-weight:700;color:#1677ff;text-shadow:0 4rpx 16rpx rgba(22,119,255,.2);letter-spacing:-.05em}.symbol-icon{margin-right:20rpx}.symbol-icon .icon{font-size:48rpx;color:#409eff}.env-item{padding:32rpx;background:linear-gradient(135deg,#f8fafc,#e6f4ff);border-radius:24rpx;display:flex;align-items:center}