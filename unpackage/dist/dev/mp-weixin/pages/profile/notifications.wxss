}
.content.data-v-13c1a359 {
  padding: 15px;
}
.uni-list.data-v-13c1a359 {
  background-color: #fff;
  border-radius: 8px;
}
.uni-list-item.data-v-13c1a359 {
  display: flex;
  justify-content: space-between;
