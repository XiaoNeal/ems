  height: 28px !important;
}
.data-v-13c1a359 .uni-switch-input.uni-switch-input-checked {
  background-color: #2b9939 !important;
  border-color: #2b9939 !important;
}


.settings-status.data-v-13c1a359 {
  display: flex;
  gap: 8px;
}
.status-icon.data-v-13c1a359 {
  font-size: 14px;
}
.sub-page.data-v-13c1a359 {
  background: #f5f5f5;
