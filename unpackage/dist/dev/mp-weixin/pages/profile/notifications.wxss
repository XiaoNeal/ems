/* 新增卡片样式 */
.card-container.data-v-13c1a359 {
  background: #fff;
  border-radius: 12px;
  padding: 0 15px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
}
.list-item.data-v-13c1a359 {
  display: flex;
  align-items: center;
  padding: 18px 0;
  position: relative;
}
.item-title.data-v-13c1a359 {
  flex: 1;
  margin-left: 12px;
  font-size: 15px;
  color: #333;
}
