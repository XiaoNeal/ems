
.container {
	font-size: 14px;
	line-height: 24px;
	background-color: #0E2264;
	height: 100%;
	overflow: auto
}
.header-container {
	display: flex;
	align-items: center;
	justify-content: space-between;
	height: 2rem;
}
.box-container {
	background: #16379A;
	height: 18rem;
	margin: 0.5rem;
	border-radius: 6px;
	color: #fff;
	padding: 0.5rem
}
.content-container {
	width: 100%;
	float: left;
	height: 77%;
	display: flex;
	flex-direction: column;
	color: #7287C6;
	position: relative;
}
.navigat-arrow {
	width: 40rpx;
	color: #fff;
	text-align: right;
	font-family: texticons;
}

