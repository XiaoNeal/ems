><block wx:if="{{pileInfo.status==='idle'}}"><button data-event-opts="{{[['tap',[['controlCharging',['start']]]]]}}" class="btn start-btn data-v-9d4e802e" bindtap="__e"><uni-icons vue-id="79bfbe3d-2" type="playfill" size="24" color="#FFF" class="data-v-9d4e802e" bind:__l="__l"></uni-icons><text class="data-v-9d4e802e">开始</text></button></block><block wx:else><button data-event-opts="{{[['tap',[['controlCharging',['stop']]]]]}}" class="btn stop-btn data-v-9d4e802e" bindtap="__e"><uni-icons vue-id="79bfbe3d-3" type="stopfill" size="24" color="#FFF" class="data-v-9d4e802e" bind:__l="__l"></uni-icons><text class="data-v-9d4e802e">停止</text></button></block></view></view><view class="data-stats data-v-9d4e802e"><view class="stats-header data-v-9d4e802e"><text class="title data-v-9d4e802e">今日充电数据</text><picker range="{{timeRanges}}" value="{{timeRangeIndex}}" data-event-opts="{{[['change',[['changeTimeRange',['$event']]]]]}}" bindchange="__e" class="data-v-9d4e802e"><view class="time-filter data-v-9d4e802e">{{''+timeRanges[timeRangeIndex]+''}}<uni-icons vue-id="79bfbe3d-4" type="arrowdown" size="20" color="#666" class="data-v-9d4e802e" bind:__l="__l"></uni-icons></view></picker></view><view class="stats-items data-v-9d4e802e"><view class="stats-item data-v-9d4e802e"><text class="item-title data-v-9d4e802e">充电次数</text><text class="item-value data-v-9d4e802e">{{pileInfo.todayChargingTimes||0}}</text></view><view class="stats-item data-v-9d4e802e"><text class="item-title data-v-9d4e802e">总充电量</text><text class="item-value data-v-9d4e802e">{{(pileInfo.todayEnergy||0)+"kWh"}}</text></view><view class="stats-item data-v-9d4e802e"><text class="item-title data-v-9d4e802e">总收入</text><text class="item-value data-v-9d4e802e">{{"¥"+(pileInfo.todayIncome||0)}}</text></view><view class="stats-item data-v-9d4e802e"><text class="item-title data-v-9d4e802e">使用率</text><text class="item-value data-v-9d4e802e">{{(pileInfo.usageRate||0)+"%"}}</text></view></view></view><view class="chart-conta