e="width:50%;margin-bottom:6px;"><text class="label data-v-9d4e802e" style="font-size:13px;color:#999;">充电量：</text><text class="value data-v-9d4e802e" style="font-size:14px;color:#333;">{{record.energy+"kWh"}}</text></view><view class="detail-item data-v-9d4e802e" style="width:50%;margin-bottom:6px;"><text class="label data-v-9d4e802e" style="font-size:13px;color:#999;">费用：</text><text class="value data-v-9d4e802e" style="font-size:14px;color:#07C160;">{{"¥"+record.fee}}</text></view><view class="detail-item data-v-9d4e802e" style="width:50%;margin-bottom:6px;"><text class="label data-v-9d4e802e" style="font-size:13px;color:#999;">时长：</text><text class="value data-v-9d4e802e" style="font-size:14px;color:#333;">{{record.duration+"小时"}}</text></view></view></view></block><block wx:if="{{$root.g0}}"><view class="no-record data-v-9d4e802e" style="padding:24px;text-align:center;color:#999;"><text class="data-v-9d4e802e">暂无充电记录</text></view></block><block wx:if="{{loadingMore}}"><view class="loading-more data-v-9d4e802e" style="padding:16px;text-align:center;"><uni-loading-icon vue-id="79bfbe3d-8" size="24" color="#07C160" class="data-v-9d4e802e" bind:__l="__l"></uni-loading-icon><text style="font-size:14px;color:#999;margin-left:8px;" class="data-v-9d4e802e">加载更多记录...</text></view></block><block wx:if="{{$root.g1}}"><view class="no-more data-v-9d4e802e" style="padding:16px;text-align:center;color:#999;font-size:14px;"><text class="data-v-9d4e802e">没有更多记录了</text></view></block></view></view><block wx:if="{{showConfirmModal}}"><view class="confirm-modal data-v-9d4e802e"><view class="modal-content data-v-9d4e802e"><text class="modal-title data-v-9d4e802e">{{confirmTitle}}</text><text class="modal-message data-v-9d4e802e">{{confirmMessage}}</text><view class="modal-buttons data-v-9d4e802e"><button data-event-opts="{{[['tap',[['closeConfirmModal',['$event']]]]]}}" class="cancel-btn data-v-9d4e802e" bindtap="__e">取消</button><button data-event-opts="{{[['tap',[['confirmAction',