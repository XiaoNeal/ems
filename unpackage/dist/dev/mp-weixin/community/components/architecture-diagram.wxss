/* 自定义弹窗样式 */
.modal-overlay.data-v-3121b1ee {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
}
.modal-content.data-v-3121b1ee {
    width: 80%;
    max-width: 500rpx;
    background-color: #fff;
    border-radius: 16rpx;
    overflow: hidden;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}
.modal-header.data-v-3121b1ee {
    padding: 32rpx;
    background-color: #FFFAF0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1rpx solid #FFE5B4;
}
.modal-icon.data-v-3121b1ee {
    font-size: 40rpx;
    margin-right: 16rpx;
    color: #F56C6C;
}
.modal-title.data-v-3121b1ee {
    font-size: 28rpx;
    font-weight: bold;
    color: #F56C6C;
}
.modal-body.data-v-3121b1ee {
    padding: 32rpx;
    line-height: 1.6;
}
.modal-text.data-v-3121b1ee {
    display: block;
    font-size: 22rpx;
    color: #606266;
    margin-bottom: 20rpx;
    text-align: center;
}
.modal-footer.data-v-3121b1ee {
    display: flex;
    border-top: 1rpx solid #EBEEF5;
    height: 88rpx;
}
.modal-cancel.data-v-3121b1ee {
    flex: 1;
    background-color: #fff;
    border: none;
    font-size: 24rpx;
    color: #909399;
    border-right: 1rpx solid #EBEEF5;
}
.modal-confirm.data-v-3121b1ee {
    flex: 1;
    background-color: #F56C6C;
    border: none;
    font-size: 24rpx;
    color: #fff;
}

