






































































































































































































































































































































































































































/* 基础样式 */
.weather-monitoring.data-v-2f29e022 {
    background-color: #f8f9fa;
    min-height: 100vh;
    /* padding: 10rpx; */
    box-sizing: border-box;
}
/* 卡片通用样式 */
.overview-card.data-v-2f29e022,
.extreme-values-card.data-v-2f29e022,
.chart-section.data-v-2f29e022,
.chart-card.data-v-2f29e022 {
    background-color: white;
    border-radius: 16rpx;
    /* box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05); */
    margin-bottom: 10rpx;
    overflow: hidden;
    /* transition: transform 0.3s ease, box-shadow 0.3s ease; */
}
.divider-line.data-v-2f29e022 {
    height: 1px;
    background-color: #eaeaea;
    margin: 10px 0;
}
/* 卡片头部样式 */
.card-header.data-v-2f29e022 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx 32rpx;
    border-bottom: 1rpx solid #f0f0f0;
}
.card-title.data-v-2f29e022 {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
    display: flex;
    align-items: center;
}
/* .card-title::before {
    content: '';
    width: 6rpx;
    height: 28rpx;
    background-color: #1890FF;
    border-radius: 3rpx;
    margin-right: 12rpx;
} */
.card-date.data-v-2f29e022 {
    font-size: 24rpx;
    color: #666;
}
/* 概览区域样式 */
.overview-content.data-v-2f29e022 {
    display: flex;
    padding: 32rpx;
    flex-direction: column;
}
.weather-icon-container.data-v-2f29e022 {
    /* width: 240rpx;
    height: 240rpx; */
    display: flex;
    /* flex-direction: column; */
    align-items: center;
    justify-content: space-around;
    margin-right: 32rpx;
    background: linear-gradient(135deg, #E6F7FF 0%, #BAE7FF 100%);
    border-radius: 16rpx;
    box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.1);
}
.weather-icon.data-v-2f29e022 {
    width: 140rpx;
    height: 140rpx;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    /* animation: float 3s ease-in-out infinite; */
}
.weather-status.data-v-2f29e022 {
    margin-top: 16rpx;
    padding: 8rpx 20rpx;
    /* background-color: rgba(255, 255, 255, 0.7); */
    border-radius: 20rpx;
}
.status-text.data-v-2f29e022 {
    font-size: 24rpx;
    font-weight: 500;
    color: #1890FF;
}
.overview-stats.data-v-2f29e022 {
    display: flex;
    flex-direction: row;
    gap: 8px;
    padding: 8px 0;
    overflow-x: auto;
    scrollbar-width: none;
    /* 隐藏滚动条 */
}
.stat-card.data-v-2f29e022 {
    min-width: 100px;
    padding: 12px;
    /* border-radius: 12px; */
    background: var(--bg-color);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}
.stat-label.data-v-2f29e022 {
    font-size: 12px;
    color: #666;
    margin-bottom: 4px;
}
.stat-value.data-v-2f29e022 {
    display: flex;
    align-items: baseline;
}
.value-number.data-v-2f29e022 {
    font-size: 12px;
    font-weight: 600;
    color: #333;
}
.value-unit.data-v-2f29e022 {
    font-size: 10px;
    color: #999;
    margin-left: 4px;
}
/* 极值数据区域样式 */
.extreme-values.data-v-2f29e022 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rpx;
    padding: 12rpx;
}
.extreme-value-card.data-v-2f29e022 {
    background: var(--gradient);
    border-radius: 16rpx;
    padding: 24rpx 10rpx;
    transition: -webkit-transform 0.2s ease;
    transition: transform 0.2s ease;
    transition: transform 0.2s ease, -webkit-transform 0.2s ease;
    flex-direction: column;
    display: flex;
    align-items: center;
}
.value-label.data-v-2f29e022 {
    font-size: 26rpx;
    color: #333;
    margin-bottom: 16rpx;
    font-weight: 600;
}
.value-display.data-v-2f29e022 {
    display: flex;
    align-items: baseline;
}
.value-int.data-v-2f29e022 {
    font-size: 40rpx;
    font-weight: 600;
    color: #1890FF;
}
.value-dec.data-v-2f29e022 {
    font-size: 32rpx;
    font-weight: 600;
    color: #1890FF;
    margin-left: 4rpx;
}
.value-unit.data-v-2f29e022 {
    font-size: 28rpx;
    color: #666;
    margin-left: 8rpx;
}
.history-card.data-v-2f29e022 {
    /* grid-column: 1 / -1; */
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
}
.history-content.data-v-2f29e022 {
    flex: 1;
}
.value-history-time.data-v-2f29e022 {
    font-size: 24rpx;
    color: #666;
    margin-top: 8rpx;
}
.timestamp.data-v-2f29e022 {
    color: #1890FF;
}
/* 图表区域样式 */
.chart-header.data-v-2f29e022 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx 32rpx;
    margin-bottom: 16rpx;
}
.chart-title.data-v-2f29e022 {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
    display: flex;
    align-items: center;
}
.chart-title.data-v-2f29e022::before {
    content: '';
    width: 6rpx;
    height: 28rpx;
    background-color: #1890FF;
    border-radius: 3rpx;
    margin-right: 12rpx;
}
.date-picker.data-v-2f29e022 {
    width: 280rpx;
    min-width: -webkit-fit-content;
    min-width: fit-content;
    border:unset
}
/* .chart-card {
    border-top: 4rpx solid var(--border-color);
} */
.chart-card-header.data-v-2f29e022 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx 32rpx 16rpx;
}
.chart-indicators.data-v-2f29e022 {
    display: flex;
}
.indicator.data-v-2f29e022 {
    display: flex;
    align-items: center;
    margin-left: 24rpx;
}
.indicator-dot.data-v-2f29e022 {
    width: 12rpx;
    height: 12rpx;
    border-radius: 50%;
    background-color: var(--color);
    margin-right: 8rpx;
}
.indicator-text.data-v-2f29e022 {
    font-size: 24rpx;
    color: #666;
}
.chart-container.data-v-2f29e022 {
    height: 520rpx;
    padding: 0 32rpx 32rpx;
}
/* 天气图标样式 */
.img-sunny.data-v-2f29e022 {
    background-image: url(data:image/png;base64,);
}
.img-cloudy-1.data-v-2f29e022 {
    background-image: url(data:image/png;base64,);
}
.img-cloudy-2.data-v-2f29e022 {
    background-image: url(data:image/png;base64,);
}
.img-rainy.data-v-2f29e022 {
    background-image: url(data:image/png;base64,);
}
/* 动画效果 */
@-webkit-keyframes float-data-v-2f29e022 {
0% {
        -webkit-transform: translateY(0rpx);
                transform: translateY(0rpx);
}
50% {
        -webkit-transform: translateY(-10rpx);
                transform: translateY(-10rpx);
}
100% {
        -webkit-transform: translateY(0rpx);
                transform: translateY(0rpx);
}
}
@keyframes float-data-v-2f29e022 {
0% {
        -webkit-transform: translateY(0rpx);
                transform: translateY(0rpx);
}
50% {
        -webkit-transform: translateY(-10rpx);
                transform: translateY(-10rpx);
}
100% {
        -webkit-transform: translateY(0rpx);
                transform: translateY(0rpx);
}
}

