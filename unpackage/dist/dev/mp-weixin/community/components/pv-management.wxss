



















































































































































































/* 基础样式 */
.container.data-v-5f2965b6 {
  padding: 10rpx;
  background-color: #f5f7fa;
}
.pv-monitor.data-v-5f2965b6 {
  background-color: #f5f7fa;
}
/* 数据卡片 */
.stats-box.data-v-5f2965b6 {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.stat-row.data-v-5f2965b6 {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.stat-row.data-v-5f2965b6:last-child { margin-bottom: 0;
}
.stat-item.data-v-5f2965b6 {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  margin: 0 8rpx;
}
.stat-item.data-v-5f2965b6:first-child { margin-left: 0;
}
.stat-item.data-v-5f2965b6:last-child { margin-right: 0;
}
.stat-label.data-v-5f2965b6 { font-size: 14px; color: #666; margin-bottom: 8rpx;
}
.stat-value.data-v-5f2965b6 { font-size: 18px; font-weight: bold; color: #4488FB;
}
.stat-unit.data-v-5f2965b6 { font-size: 12px; color: #666; margin-left: 4rpx;
}
/* 日期选择器：修复样式 */
.date-selector.data-v-5f2965b6 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 100; /* 保证层级 */
}
.date-tabs.data-v-5f2965b6 {
  display: flex;
  gap: 10rpx;
}
.date-tab.data-v-5f2965b6 {
  padding: 6rpx 16rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 20rpx;
  font-size: 15px;
  color: #666;
  background: #f8f9fa;
  cursor: pointer;
}
.date-tab.active.data-v-5f2965b6 {
  background: #4488FB;
  color: #fff;
  border-color: #4488FB;
}
/* 日期显示文字：可点击、样式美观 */
.date-display.data-v-5f2965b6 {
  font-size: 16px;
  color: #333;
  font-weight: 600;
  padding: 8rpx 10rpx;
  border-radius: 8rpx;
  background: #f8f9fa;
}
.date-display.data-v-5f2965b6:active {
  background: #e8e8e8;
}
/* 图表区域 */
.chart-section.data-v-5f2965b6 {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.chart-card.data-v-5f2965b6 {
  background-color: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}
.chart-header.data-v-5f2965b6 {
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f0f4ff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.chart-title.data-v-5f2965b6 { font-size: 16px; font-weight: 600; color: #333;
}
.chart-controls.data-v-5f2965b6 { display: flex; gap: 12rpx;
}
.chart-tab.data-v-5f2965b6 {
  padding: 6rpx 16rpx;
  border: 1rpx solid #4488FB;
  border-radius: 16rpx;
  font-size: 12px;
  color: #4488FB;
  background: #f0f4ff;
}
.chart-body.data-v-5f2965b6 { padding: 20rpx;
}
.power-chart.data-v-5f2965b6,
.generation-chart.data-v-5f2965b6 {
  width: 100%;
  height: 400rpx;
}

