
.table-container.data-v-44fa1344 {
    border: 1px solid #e6ebf5;
    border-radius: 4px;
    overflow: hidden;
    margin-top: 15px;
}

/* 横向滚动容器 */
.table-scroll-container.data-v-44fa1344 {
