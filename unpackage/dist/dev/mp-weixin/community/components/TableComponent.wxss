    min-width: fit-content;
    /* 确保表格不会被压缩 */
}
.table-row.data-v-44fa1344:last-child {
    border-bottom: none;
}
.table-cell.data-v-44fa1344 {
    flex: 0 0 auto;
    /* 禁用flex的自动伸缩 */
    text-align: left;
    padding: 10px 12px;
    font-size: 14px;
