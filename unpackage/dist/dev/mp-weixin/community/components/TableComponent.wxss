}
.table-header-cell.data-v-44fa1344 {
    flex: 0 0 auto;
    /* 禁用flex的自动伸缩 */
    text-align: left;
    padding: 10px 12px;
    font-size: 14px;
    box-sizing: border-box;
    min-width: 60px;
    /* 减小最小列宽 */
}
.table-body.data-v-44fa1344 {
    display: flex;
    flex-direction: column;
}
.table-row.data-v-44fa1344 {
    display: flex;
    border-bottom: 1px solid #e6ebf5;
