




















































































































































































































































































/* 基础布局 */
.page-container.data-v-3abb3f3d {
  min-height: 100vh;
  background-color: #f5f7fa;
  color: #333;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.main-content.data-v-3abb3f3d {
  flex: 1;
  padding-top: var(--custom-nav-bar-height, 48px);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: calc(var(--custom-nav-bar-height, 48px) + 20px) 16px 20px;
  box-sizing: border-box;
  position: relative;
}
/* 余额信息卡片 */
.balance-card.data-v-3abb3f3d {
  width: 100%;
  max-width: 340px;
  background: linear-gradient(135deg, #1e5fc8, #409eff);
  border-radius: 16px;
  padding: 18px 20px;
  margin-bottom: 28px;
  box-shadow: 0 8px 20px rgba(64, 158, 255, 0.2);
}
.balance-info.data-v-3abb3f3d {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.balance-label.data-v-3abb3f3d {
  color: rgba(255, 255, 255, 0.9);
  font-size: 15px;
}
.balance-amount.data-v-3abb3f3d {
  color: #ffffff;
  font-size: 22px;
  font-weight: 700;
  margin: 0 10px;
  flex: 1;
  text-align: center;
}
.recharge-btn.data-v-3abb3f3d {
  background-color: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  border: none;
  border-radius: 20px;
  padding: 6px 16px;
  font-size: 14px;
  font-weight: 600;
  height: auto;
  line-height: normal;
  transition: all 0.3s ease;
}
.recharge-btn.data-v-3abb3f3d:active {
  background-color: rgba(255, 255, 255, 0.3);
  -webkit-transform: scale(0.95);
          transform: scale(0.95);
}
/* 扫码引导提示 */
.scan-guide.data-v-3abb3f3d {
  margin-bottom: 26px;
  text-align: center;
  width: 100%;
  max-width: 340px;
}
.guide-text.data-v-3abb3f3d {
  font-size: 18px;
  color: #333;
  font-weight: 600;
}
/* 扫码区域容器 */
.scan-area-container.data-v-3abb3f3d {
  width: 100%;
  max-width: 340px;
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}
/* 扫码区域 */
.scan-area.data-v-3abb3f3d {
  width: 340px;
  height: 340px;
  position: relative;
  overflow: hidden;
  border-radius: 16px;
  background-color: #000000;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}
/* 扫描辅助边框 */
.scan-border.data-v-3abb3f3d {
  width: 300px;
  height: 300px;
  position: absolute;
  top: 50%;
  left: 50%;
  -webkit-transform: translate(-50%, -50%);
          transform: translate(-50%, -50%);
  border-radius: 12px;
  z-index: 2;
  transition: all 0.3s ease;
}
.scan-border.scanning.data-v-3abb3f3d {
  box-shadow: 0 0 0 2000px rgba(0, 0, 0, 0.5), 0 0 30px rgba(64, 158, 255, 0.6);
}
/* 扫码框 */
.scan-frame.data-v-3abb3f3d {
  width: 260px;
  height: 260px;
  position: absolute;
  top: 50%;
  left: 50%;
  -webkit-transform: translate(-50%, -50%);
          transform: translate(-50%, -50%);
  overflow: hidden;
  z-index: 3;
}
/* 扫码线动画 */
.scan-line.data-v-3abb3f3d {
  position: absolute;
  left: 0;
  width: 100%;
  height: 3px;
  background: linear-gradient(90deg, transparent, #409eff, transparent);
  box-shadow: 0 0 15px 2px rgba(64, 158, 255, 0.8);
  z-index: 4;
}
/* 扫描网格背景 */
.scan-grid.data-v-3abb3f3d {
  position: absolute;
  width: 100%;
  height: 100%;
  background-image:
    linear-gradient(to bottom, rgba(64, 158, 255, 0.1) 1px, transparent 1px),
    linear-gradient(to right, rgba(64, 158, 255, 0.1) 1px, transparent 1px);
  background-size: 20px 20px;
  z-index: 3;
}
/* 角落标记 */
.corner.data-v-3abb3f3d {
  width: 24px;
  height: 24px;
  position: absolute;
  border: 3px solid #409eff;
  z-index: 5;
  background: transparent;
}
.top-left.data-v-3abb3f3d {
  top: 0;
  left: 0;
  border-right: none;
  border-bottom: none;
}
.top-right.data-v-3abb3f3d {
  top: 0;
  right: 0;
  border-left: none;
  border-bottom: none;
}
.bottom-left.data-v-3abb3f3d {
  bottom: 0;
  left: 0;
  border-right: none;
  border-top: none;
}
.bottom-right.data-v-3abb3f3d {
  bottom: 0;
  right: 0;
  border-left: none;
  border-top: none;
}
/* 扫描区域外的遮罩 */
.scan-mask.data-v-3abb3f3d {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1;
  padding: 40px;
  box-sizing: border-box;
  pointer-events: none;
}
/* 扫描状态图标 */
.scan-status-icon.data-v-3abb3f3d {
  position: absolute;
  top: 50%;
  left: 50%;
  -webkit-transform: translate(-50%, -50%);
          transform: translate(-50%, -50%);
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100px;
  height: 100px;
}
/* 扫描区域提示 */
.scan-hint.data-v-3abb3f3d {
  margin-top: 16px;
  text-align: center;
  color: #666;
  font-size: 14px;
  z-index: 1;
  width: 100%;
}
/* 扫码状态提示 */
.scan-status.data-v-3abb3f3d {
  text-align: center;
  margin: 20px 0;
  font-size: 15px;
  padding: 10px 16px;
  border-radius: 8px;
  transition: all 0.3s ease;
  width: 100%;
  max-width: 340px;
}
.scan-status.error.data-v-3abb3f3d {
  color: #f56c6c;
  background-color: rgba(245, 108, 108, 0.1);
}
.scan-status.success.data-v-3abb3f3d {
  color: #67c23a;
  background-color: rgba(103, 194, 58, 0.1);
}
/* 功能按钮区 - 对齐优化版 */
.scan-actions.data-v-3abb3f3d {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 30px;
  /* 调整间距使按钮更紧凑 */
  width: 100%;
  max-width: 340px;
  margin: 20px 0 30px;
  padding: 0 10px;
  box-sizing: border-box;
}
.action-btn.data-v-3abb3f3d {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #666;
  font-size: 15px;
  transition: all 0.3s ease;
  padding: 16px 20px;
  /* 调整内边距使按钮高度一致 */
  border-radius: 12px;
  cursor: pointer;
  background-color: #ffffff;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
  width: 130px;
  /* 增加宽度以适应文字 */
  height: 100px;
  /* 固定高度确保对齐 */
}
.action-btn.primary.data-v-3abb3f3d {
  background-color: #409eff;
  color: #ffffff;
}
.action-btn.data-v-3abb3f3d:active {
  -webkit-transform: scale(0.96);
          transform: scale(0.96);
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
}
.action-btn.disabled.data-v-3abb3f3d {
  opacity: 0.5;
  pointer-events: none;
}
/* 按钮图标样式 */
.action-btn uni-icons.data-v-3abb3f3d {
  margin-bottom: 10px;
  /* 图标与文字间距 */
}
/* 按钮文字样式 */
.action-btn text.data-v-3abb3f3d {
  text-align: center;
  line-height: 1.4;
}
/* 底部提示 */
.scan-footer.data-v-3abb3f3d {
  color: #999;
  font-size: 12px;
  text-align: center;
  padding: 16px 20px;
  margin-top: auto;
  line-height: 1.5;
}
/* 弹窗样式 */
.modal-backdrop.data-v-3abb3f3d {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 998;
  -webkit-animation: fadeIn-data-v-3abb3f3d 0.3s ease;
          animation: fadeIn-data-v-3abb3f3d 0.3s ease;
}
.modal.data-v-3abb3f3d {
  position: fixed;
  top: 50%;
  left: 50%;
  -webkit-transform: translate(-50%, -50%) scale(0.8);
          transform: translate(-50%, -50%) scale(0.8);
  opacity: 0;
  z-index: 999;
  width: 90%;
  max-width: 360px;
  -webkit-animation: scaleIn-data-v-3abb3f3d 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
          animation: scaleIn-data-v-3abb3f3d 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}
@-webkit-keyframes fadeIn-data-v-3abb3f3d {
from {
    opacity: 0;
}
to {
    opacity: 1;
}
}
@keyframes fadeIn-data-v-3abb3f3d {
from {
    opacity: 0;
}
to {
    opacity: 1;
}
}
@-webkit-keyframes scaleIn-data-v-3abb3f3d {
to {
    -webkit-transform: translate(-50%, -50%) scale(1);
            transform: translate(-50%, -50%) scale(1);
    opacity: 1;
}
}
@keyframes scaleIn-data-v-3abb3f3d {
to {
    -webkit-transform: translate(-50%, -50%) scale(1);
            transform: translate(-50%, -50%) scale(1);
    opacity: 1;
}
}
.modal-content.data-v-3abb3f3d {
  background-color: #ffffff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
